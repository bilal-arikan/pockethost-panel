# Copy to .env and fill in real values. .env is gitignored.

# --- Basic Auth (panel login) ---
PANEL_USER=admin
PANEL_PASS=change-me

# --- Panel ---
PANEL_PORT=8096

# --- PocketHost layout (HOST paths; PH_HOME is bind-mounted 1:1) ---
PH_HOME=/home/user/services/pockethost/home
PH_PORT=8095
PH_APEX_DOMAIN=pocket.example.com
PH_SERVICE=pockethost

# Per-instance default admin (matches the patched auto-admin plugin).
PH_AUTO_ADMIN_LOGIN=admin@example.com
PH_AUTO_ADMIN_PASSWORD=change-me

# --- Service control over SSH ---
# The container runs as the host user (1000) and cannot use systemd directly,
# so the delete flow ssh-es into the host and runs `sudo systemctl`. PH_CTL_KEY
# is a host private key whose public key is in the host user's authorized_keys
# and whose user has passwordless `sudo systemctl`. Mounted read-only at
# /keys/host_ctl inside the container. Set any PH_*_CMD to "" to disable it.
PH_CTL_KEY=/home/user/services/pockethost-panel/secrets/panel_ctl_ed25519
PH_STOP_CMD=ssh -i /keys/host_ctl -F /dev/null -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes user@127.0.0.1 sudo systemctl stop pockethost
PH_START_CMD=ssh -i /keys/host_ctl -F /dev/null -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes user@127.0.0.1 sudo systemctl start pockethost
PH_STATUS_CMD=ssh -i /keys/host_ctl -F /dev/null -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes user@127.0.0.1 sudo systemctl is-active pockethost
