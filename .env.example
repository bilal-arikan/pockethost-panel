# Copy to .env and fill in. .env is gitignored.

# --- Panel (management UI) basic auth ---
PANEL_USER=admin
PANEL_PASS=change-me

# --- Server ---
PORT=8090
# Subdomain routing apex. `localhost` works with zero DNS setup
# (browsers resolve *.localhost to 127.0.0.1). Use a real wildcard
# domain in production, e.g. pocket.example.com.
APEX_DOMAIN=localhost

# --- Default superuser created for every new instance ---
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me

# --- Optional tuning ---
# Stop an instance after N ms idle (0 = never; instances stay up once started).
IDLE_TIMEOUT_MS=0
# Internal loopback port range for spawned PocketBase processes.
INSTANCE_PORT_BASE=9001
INSTANCE_PORT_MAX=9999
